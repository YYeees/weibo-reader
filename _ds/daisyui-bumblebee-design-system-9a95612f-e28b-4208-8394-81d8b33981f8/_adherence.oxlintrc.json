{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/navigation/**",
              "ui_kits/shop/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|variant|icon|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: color, variant, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|outline|dash)$/]",
        "message": "<Alert> variant must be one of 'soft' | 'outline' | 'dash'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|size|rounded|status|children|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, size, rounded, status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='rounded'] > Literal[value!=/^(?:rounded|circle|square)$/]",
        "message": "<Avatar> rounded must be one of 'rounded' | 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|offline)$/]",
        "message": "<Avatar> status must be one of 'online' | 'offline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: color, variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|soft|ghost)$/]",
        "message": "<Badge> variant must be one of 'outline' | 'soft' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|size|shape|wide|block|active|loading|startIcon|endIcon|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, color, size, shape, wide, block, active, loading, startIcon, endIcon, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|outline|soft|ghost|link|dash)$/]",
        "message": "<Button> variant must be one of 'default' | 'outline' | 'soft' | 'ghost' | 'link' | 'dash'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:square|circle|wide|block)$/]",
        "message": "<Button> shape must be one of 'square' | 'circle' | 'wide' | 'block'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:bordered|side|image|imageAlt|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: bordered, side, image, imageAlt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: color, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Checkbox> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: color, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Input> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Progress'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|value|max|key|ref|className|style|children)$/]",
        "message": "<Progress> doesn't accept that prop. Declared props: color, value, max."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: color, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Radio> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: color, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Select> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|value|desc|figure|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: title, value, desc, figure."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|size|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: color, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Toggle> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
